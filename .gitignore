# ---- Secrets / local config -------------------------------------------------
# Stage 3 reads Azure OpenAI credentials from these; never commit them.
.env
.env.*
!.env.example

# ---- Python byte-compiled / cache -------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Packaging / build artifacts --------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
MANIFEST

# ---- Virtual environments ---------------------------------------------------
.venv/
venv/
env/
ENV/

# ---- Test / type / lint caches ----------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ---- Pipeline run outputs (generated next to data roots, never source) ------
# Run manifests + batch state are reproducible from a run; keep them out of git.
# (Per-PDF sidecars are written next to the source PDFs in the data root, which
#  lives outside this repo, so they need no pattern here.)
extract-run-manifest.json
stage2-run-manifest.json
stage3-run-manifest.json
stage3-batch-state.json
*.tmp
# Summary scanner outputs + incremental cache (written next to data roots).
dataset-summary.json
dataset-summary.md
dataset-summary.html
corpus-summary.json
corpus-summary.md
corpus-summary.html
quarantine-list.json
.summary-cache.json
# Stage-7 staged vector store (written next to data roots).
.embeddings/
# Guard: real datasets live OUTSIDE the repo (C:\Projects\Data\epstein); never commit a DataSet-*/ tree
# that lands in the repo by accident (e.g. a stray test corpus).
/DataSet-*/

# ---- Editor / OS ------------------------------------------------------------
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
